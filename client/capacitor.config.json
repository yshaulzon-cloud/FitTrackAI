{
  "appId": "com.areto.app",
  "appName": "Areto",
  "webDir": "dist",
  "android": {
    "allowMixedContent": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "launchAutoHide": true,
      "backgroundColor": "#0a0e1a",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true,
      "androidScaleType": "CENTER_CROP"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0a0e1a"
    }
  }
}
