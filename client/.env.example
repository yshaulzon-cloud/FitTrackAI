# Copy this file to either:
#   .env.development   — used by `npm run dev`
#   .env.production    — used by `npm run build`
#
# VITE_API_URL is the full base URL of the Areto API.
# • Local dev: leave empty or http://localhost:3001
# • Production: https://bodysync-api-admm.onrender.com (note the -admm suffix;
#   the bare bodysync-api.onrender.com does not exist) — or api.digtal-c.co.il

VITE_API_URL=
